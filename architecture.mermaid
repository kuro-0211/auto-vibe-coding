graph TB
    subgraph USER["👤 사용자"]
        INPUT["Vibe 입력<br/>(추상적 의도/요구사항)"]
    end

    subgraph UI["🖥️ Streamlit Dashboard"]
        MONITOR["워크플로우 모니터링"]
        RESULT["최종 결과물 출력"]
    end

    subgraph ORCHESTRATION["🧠 오케스트레이션 레이어"]
        CREWAI["CrewAI<br/>역할 기반 협업"]
        LANGGRAPH["LangGraph<br/>순환 제어 구조"]
    end

    subgraph AGENTS["🤖 멀티 에이전트 시스템"]
        subgraph PM["PM Agent (팀장)"]
            PM_PARSE["의도 해석 &<br/>태스크 분해"]
            PM_VERIFY["의도 검증<br/>(Intent Verification)"]
        end

        subgraph RESEARCH["Researcher Agent (연구원)"]
            RES_SEARCH["기술 문서 검색"]
            RES_REFINE["검색 결과 정제"]
        end

        subgraph DEV["Developer Agent (개발자)"]
            DEV_CODE["코드 생성"]
            DEV_FIX["에러 분석 & 수정"]
        end
    end

    subgraph CLOUD_LLM["☁️ Cloud LLM"]
        GPT4O["OpenAI GPT-4o<br/>(학교 API Gateway)"]
        GEMINI["Gemini 3 Flash<br/>(무료 티어)"]
    end

    subgraph LOCAL_LLM["🏠 Local LLM (Ollama)"]
        QWEN["Qwen2.5-Coder"]
        LLAMA["Llama 3.3"]
        GPU["NVIDIA RTX 3080<br/>추론 가속"]
    end

    subgraph SANDBOX["🐳 Docker Sandbox"]
        EXEC["격리된 코드 실행"]
        ERR["에러 로그 수집 & 정제"]
    end

    subgraph CONTEXT["📦 컨텍스트 관리"]
        COMPRESS["토큰 압축 · 대화 요약"]
    end

    %% ── 메인 흐름 (위 → 아래) ──
    INPUT --> MONITOR
    MONITOR --> CREWAI
    CREWAI <--> LANGGRAPH
    CREWAI --> PM_PARSE

    %% ── 에이전트 간 흐름 ──
    PM_PARSE --> RES_SEARCH
    RES_REFINE --> DEV_CODE

    %% ── Cloud LLM 연결 ──
    PM -.->|기획 · 설계 · 검증| GPT4O
    RESEARCH -.->|리서치| GEMINI

    %% ── Local LLM 연결 ──
    DEV -.->|코드 생성 · 수정| QWEN
    DEV -.->|코드 수정| LLAMA
    QWEN --> GPU
    LLAMA --> GPU

    %% ── 실행 ──
    DEV_CODE --> EXEC

    %% ── 실행 결과 분기 ──
    EXEC -->|성공| PM_VERIFY
    EXEC -->|실패| ERR

    %% ── Self-Correction (점선) ──
    ERR -.->|재시도| DEV_FIX
    DEV_FIX -.-> EXEC

    %% ── 의도 검증 결과 ──
    PM_VERIFY -->|통과| RESULT
    PM_VERIFY -.->|미달| PM_PARSE

    %% ── 컨텍스트 ──
    AGENTS <-.-> COMPRESS

    %% ── 스타일 ──
    classDef user fill:#4A90D9,stroke:#2E6CB0,color:#fff,stroke-width:2px
    classDef ui fill:#50C878,stroke:#3DA35D,color:#fff,stroke-width:2px
    classDef agent fill:#FFB347,stroke:#E09030,color:#333,stroke-width:2px
    classDef cloud fill:#9B89B3,stroke:#7B6B93,color:#fff,stroke-width:2px
    classDef local fill:#FF6B6B,stroke:#D94545,color:#fff,stroke-width:2px
    classDef sandbox fill:#4DB8DB,stroke:#2E96B5,color:#fff,stroke-width:2px
    classDef context fill:#95A5A6,stroke:#7F8C8D,color:#fff,stroke-width:2px

    class INPUT user
    class MONITOR,RESULT ui
    class PM_PARSE,PM_VERIFY,RES_SEARCH,RES_REFINE,DEV_CODE,DEV_FIX agent
    class GPT4O,GEMINI cloud
    class QWEN,LLAMA,GPU local
    class EXEC,ERR sandbox
    class COMPRESS context
