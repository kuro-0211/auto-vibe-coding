graph LR
    %% ── 입력 ──
    INPUT["👤 사용자<br/>Vibe 입력"]

    %% ── UI ──
    DASH["📊 Streamlit<br/>대시보드 :8501"]

    %% ── 오케스트레이션 ──
    subgraph ORCH["⚙️ 오케스트레이션"]
        CREWAI["CrewAI"] <--> LANGGRAPH["LangGraph"]
    end

    %% ── 에이전트 ──
    subgraph AGENTS["🤖 멀티 에이전트"]
        PM["🎯 PM Agent<br/>의도 해석 · 태스크 분해 · 검증"]
        RES["🔍 Researcher<br/>기술 리서치 · 문서 정제"]
        DEV["💻 Developer<br/>코드 생성 · 수정"]
    end

    %% ── LLM ──
    subgraph CLOUD["☁️ Cloud LLM"]
        GPT["GPT-4o<br/>학교 API Gateway"]
        GEM["Gemini 3 Flash<br/>무료 티어"]
    end

    subgraph LOCAL["🏠 Local LLM · Ollama"]
        QWEN["Qwen2.5-Coder"]
        LLAMA["Llama 3.3"]
        GPU["🎮 RTX 3080"]
    end

    %% ── 실행 ──
    subgraph SANDBOX["🐳 Docker Sandbox"]
        EXEC["코드 실행<br/>격리 환경"]
        ERR["에러 로그<br/>수집 · 정제"]
    end

    %% ── 결과 ──
    OUTPUT["✅ 결과물 출력"]

    %% ── 메인 플로우 ──
    INPUT --> DASH --> ORCH --> PM
    PM --> RES --> DEV
    PM --> DEV

    %% ── LLM 연결 ──
    PM -.->|기획 · 검증| GPT
    RES -.->|리서치| GEM
    DEV -->|코드 생성| QWEN
    DEV -->|코드 수정| LLAMA
    QWEN --> GPU
    LLAMA --> GPU

    %% ── 실행 루프 ──
    DEV --> EXEC
    EXEC -->|성공| PM
    EXEC -->|실패| ERR -->|Self-Correction| DEV

    %% ── 의도 검증 ──
    PM -->|의도 부합| OUTPUT
    PM -.->|미달 · 재작업| DEV

    %% ── 스타일 ──
    classDef input fill:#4A90D9,stroke:#2E6CB0,color:#fff,stroke-width:2px
    classDef ui fill:#50C878,stroke:#3DA35D,color:#fff,stroke-width:2px
    classDef orch fill:#2496ED,stroke:#1A7BC8,color:#fff,stroke-width:2px
    classDef agent fill:#FFB347,stroke:#E09030,color:#333,stroke-width:2px
    classDef cloud fill:#9B89B3,stroke:#7B6B93,color:#fff,stroke-width:2px
    classDef local fill:#76B900,stroke:#5A8F00,color:#fff,stroke-width:2px
    classDef sandbox fill:#FF6B6B,stroke:#D94545,color:#fff,stroke-width:2px
    classDef output fill:#2ECC71,stroke:#27AE60,color:#fff,stroke-width:2px

    class INPUT input
    class DASH ui
    class CREWAI,LANGGRAPH orch
    class PM,RES,DEV agent
    class GPT,GEM cloud
    class QWEN,LLAMA,GPU local
    class EXEC,ERR sandbox
    class OUTPUT output
