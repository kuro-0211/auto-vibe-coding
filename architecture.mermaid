graph LR
    %% ─── Input ───
    A(Vibe Input):::mint --> B(Streamlit\n:8501):::blue

    %% ─── Orchestration ───
    subgraph orch [" Orchestration "]
        direction TB
        CR(CrewAI):::slate <--> LG(LangGraph):::slate
    end

    %% ─── Agent Pipeline ───
    subgraph agents [" Agent Pipeline "]
        direction TB
        PM(PM Agent\nIntent Parse · Verify):::amber
        RES(Researcher\nTech Search · Refine):::violet
        DEV(Developer\nCode Gen · Fix):::green
    end

    %% ─── Cloud LLM ───
    subgraph cloud [" Cloud LLM "]
        direction TB
        GPT(GPT-4o\nSchool API GW):::blue
        GEM(Gemini 3 Flash\nFree Tier):::blue
    end

    %% ─── Local LLM ───
    subgraph local [" Local LLM — Ollama "]
        direction TB
        QW(Qwen2.5-Coder):::red
        LL(Llama 3.3):::red
        GPU(RTX 3080):::red
    end

    %% ─── Docker Sandbox ───
    subgraph sandbox [" Docker Sandbox "]
        direction TB
        EXEC(Isolated\nExecution):::slate
        ERR(Error Log\nParse):::slate
    end

    %% ─── Context ───
    subgraph ctx [" Context Mgmt "]
        COMP(Token\nCompression):::grey
    end

    %% ─── Output ───
    OUT(Output):::mint

    %% ─── Main Flow ───
    B --> orch --> PM
    PM --> RES --> DEV
    PM --> DEV

    %% ─── LLM Connections (dotted) ───
    PM -.-|plan · verify| GPT
    RES -.-|research| GEM
    DEV -->|generate| QW --> GPU
    DEV -->|fix| LL --> GPU

    %% ─── Execution Loop ───
    DEV --> EXEC
    EXEC -- success --> PM
    EXEC -. fail .-> ERR -. self-correct .-> DEV

    %% ─── Intent Gate ───
    PM --> OUT
    PM -. rework .-> DEV

    %% ─── Context Link ───
    agents -.- ctx

    %% ─── Styles ───
    classDef mint fill:#d1fae5,stroke:#6ee7b7,color:#064e3b
    classDef blue fill:#dbeafe,stroke:#93c5fd,color:#1e3a5f
    classDef amber fill:#fef3c7,stroke:#fcd34d,color:#78350f
    classDef violet fill:#ede9fe,stroke:#c4b5fd,color:#3b0764
    classDef green fill:#dcfce7,stroke:#86efac,color:#14532d
    classDef red fill:#fee2e2,stroke:#fca5a5,color:#7f1d1d
    classDef slate fill:#f1f5f9,stroke:#cbd5e1,color:#1e293b
    classDef grey fill:#f3f4f6,stroke:#d1d5db,color:#374151

    style orch fill:none,stroke:#e2e8f0,stroke-width:1px,stroke-dasharray:6,color:#94a3b8
    style agents fill:none,stroke:#e2e8f0,stroke-width:1px,stroke-dasharray:6,color:#94a3b8
    style cloud fill:none,stroke:#e2e8f0,stroke-width:1px,stroke-dasharray:6,color:#94a3b8
    style local fill:none,stroke:#e2e8f0,stroke-width:1px,stroke-dasharray:6,color:#94a3b8
    style sandbox fill:none,stroke:#e2e8f0,stroke-width:1px,stroke-dasharray:6,color:#94a3b8
    style ctx fill:none,stroke:#e2e8f0,stroke-width:1px,stroke-dasharray:6,color:#94a3b8
