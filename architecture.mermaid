graph LR
    %% ─── 메인 파이프라인 (좌 → 우 직선 흐름) ───

    IN(Vibe 입력):::mint
    UI(Streamlit\n대시보드):::blue

    subgraph orch [" 오케스트레이션 "]
        CR(CrewAI):::slate
        LG(LangGraph):::slate
    end

    subgraph agents [" 에이전트 "]
        PM(PM 에이전트\n의도 해석 · 검증):::amber
        RES(리서처\n기술 조사):::violet
        DEV(개발자\n코드 생성):::green
    end

    subgraph exec [" 실행 "]
        SB(Docker 샌드박스\n격리 실행):::slate
        ERR(에러 분석):::red
    end

    OUT(결과물 출력):::mint

    %% ─── 클라우드 / 로컬 LLM ───

    CLOUD(Cloud LLM\nGPT-4o · Gemini):::blue
    LOCAL(Local LLM\nOllama · RTX 3080):::red

    %% ─── 메인 흐름 ───
    IN --> UI --> orch
    CR <--> LG
    orch --> PM
    PM --> RES
    RES --> DEV
    DEV --> SB

    %% ─── LLM 연결 (점선) ───
    PM -.- CLOUD
    RES -.- CLOUD
    DEV -.- LOCAL

    %% ─── 실행 결과 분기 ───
    SB -- 성공 --> OUT
    SB -. 실패 .-> ERR -. 재시도 .-> DEV

    %% ─── 스타일 ───
    classDef mint fill:#d1fae5,stroke:#6ee7b7,color:#064e3b
    classDef blue fill:#dbeafe,stroke:#93c5fd,color:#1e3a5f
    classDef amber fill:#fef3c7,stroke:#fcd34d,color:#78350f
    classDef violet fill:#ede9fe,stroke:#c4b5fd,color:#3b0764
    classDef green fill:#dcfce7,stroke:#86efac,color:#14532d
    classDef red fill:#fee2e2,stroke:#fca5a5,color:#7f1d1d
    classDef slate fill:#f1f5f9,stroke:#cbd5e1,color:#1e293b

    style orch fill:none,stroke:#e2e8f0,stroke-width:1px,stroke-dasharray:6,color:#94a3b8
    style agents fill:none,stroke:#e2e8f0,stroke-width:1px,stroke-dasharray:6,color:#94a3b8
    style exec fill:none,stroke:#e2e8f0,stroke-width:1px,stroke-dasharray:6,color:#94a3b8
