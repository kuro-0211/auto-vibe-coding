graph TB
    subgraph USER["👤 사용자"]
        INPUT["Vibe 입력<br/>(추상적 의도/요구사항)"]
    end

    subgraph HOST["🪟 Windows Host"]
        DRIVER["NVIDIA GPU Driver"]
        DOCKER_DESKTOP["Docker Desktop<br/>(WSL2 백엔드)"]
    end

    subgraph WSL2["🐧 WSL2 Ubuntu 24.04"]
        TOOLKIT["NVIDIA Container Toolkit"]

        subgraph DOCKER["🐳 Docker Compose"]

            subgraph OLLAMA_SVC["ollama 서비스"]
                QWEN["Qwen2.5-Coder"]
                LLAMA["Llama 3.3"]
                GPU["🎮 RTX 3080<br/>GPU 패스스루"]
            end

            subgraph ENGINE_SVC["engine 서비스"]
                subgraph ORCHESTRATION["오케스트레이션"]
                    CREWAI["CrewAI<br/>역할 기반 협업"]
                    LANGGRAPH["LangGraph<br/>순환 제어"]
                end

                subgraph AGENTS["멀티 에이전트"]
                    PM["🎯 PM Agent<br/>의도 해석 · 검증"]
                    RESEARCHER["🔍 Researcher<br/>기술 리서치"]
                    DEVELOPER["💻 Developer<br/>코드 생성 · 수정"]
                end

                subgraph CTX["컨텍스트 관리"]
                    COMPRESS["토큰 압축<br/>(TOON)"]
                end
            end

            subgraph SANDBOX_SVC["sandbox 서비스"]
                EXEC["격리된 코드 실행"]
                ERRLOG["에러 로그 수집 · 정제"]
                SECURITY["🔒 보안 격리<br/>네트워크 차단 · 읽기전용<br/>리소스 제한 · 권한 최소화"]
            end

            subgraph DASH_SVC["dashboard 서비스"]
                STREAMLIT["📊 Streamlit<br/>:8501"]
            end

        end
    end

    subgraph CLOUD["☁️ Cloud LLM"]
        GPT4O["OpenAI GPT-4o<br/>(학교 API Gateway)"]
        GEMINI["Gemini 3 Flash<br/>(무료 티어)"]
    end

    %% 사용자 → UI
    INPUT --> STREAMLIT
    STREAMLIT --> CREWAI

    %% 오케스트레이션 → 에이전트
    CREWAI <--> LANGGRAPH
    CREWAI --> PM
    PM --> RESEARCHER
    PM --> DEVELOPER
    RESEARCHER --> DEVELOPER

    %% Cloud LLM 연결 (점선)
    PM -.->|기획/설계/검증| GPT4O
    RESEARCHER -.->|리서치| GEMINI

    %% Local LLM 연결
    DEVELOPER -->|코드 생성| QWEN
    DEVELOPER -->|코드 수정| LLAMA
    QWEN --> GPU
    LLAMA --> GPU

    %% 샌드박스 실행 루프
    DEVELOPER --> EXEC
    EXEC -->|✅ 성공| PM
    EXEC -->|❌ 실패| ERRLOG
    ERRLOG --> DEVELOPER

    %% 의도 검증 분기
    PM -->|통과 ✅| STREAMLIT
    PM -->|미달 🔄| DEVELOPER

    %% 컨텍스트 관리
    AGENTS <--> COMPRESS

    %% 인프라 연결
    DOCKER_DESKTOP --> WSL2
    DRIVER --> TOOLKIT
    TOOLKIT --> GPU

    %% 스타일
    classDef user fill:#4A90D9,stroke:#2E6CB0,color:#fff,stroke-width:2px
    classDef host fill:#0078D4,stroke:#005A9E,color:#fff,stroke-width:2px
    classDef wsl fill:#E95420,stroke:#C7351A,color:#fff,stroke-width:2px
    classDef docker fill:#2496ED,stroke:#1A7BC8,color:#fff,stroke-width:2px
    classDef agent fill:#FFB347,stroke:#E09030,color:#333,stroke-width:2px
    classDef cloud fill:#9B89B3,stroke:#7B6B93,color:#fff,stroke-width:2px
    classDef local fill:#76B900,stroke:#5A8F00,color:#fff,stroke-width:2px
    classDef sandbox fill:#FF6B6B,stroke:#D94545,color:#fff,stroke-width:2px
    classDef ui fill:#50C878,stroke:#3DA35D,color:#fff,stroke-width:2px

    class INPUT user
    class DRIVER,DOCKER_DESKTOP host
    class TOOLKIT wsl
    class PM,RESEARCHER,DEVELOPER agent
    class GPT4O,GEMINI cloud
    class QWEN,LLAMA,GPU local
    class EXEC,ERRLOG,SECURITY sandbox
    class STREAMLIT ui
    class CREWAI,LANGGRAPH docker
    class COMPRESS docker
