---
title: Auto Vibe Coding Engine — 시스템 아키텍처
---

%%  ================================================================
%%  전체 파이프라인
%%  ================================================================
flowchart TD
    INPUT([" 🧑 사용자 입력\n키워드 / 목적 "]):::user

    subgraph RA["① Research Agent"]
        direction TB
        TAVILY["🔍 Tavily\n웹 검색"]:::tool
        GEMINI_R["✨ Gemini 2.5 Flash\n내용 정리 / 요약"]:::gemini
        TAVILY --> GEMINI_R
    end

    subgraph CA["② Code Agent  (코드 불필요 시 스킵)"]
        direction TB
        OLLAMA_G["🦙 Ollama\nqwen2.5-coder\n코드 생성"]:::ollama
        GPT_R["🤖 GPT-5.4-mini\n코드 리뷰 + 의도 검증\n(학교 API)"]:::gpt
        DOCKER["🐳 Docker 샌드박스\n코드 실행\n타임아웃 60초 / 메모리 1GB"]:::docker
        OLLAMA_G --> GPT_R
        GPT_R --> DOCKER
    end

    subgraph SC["🔄 Self-Correction Loop"]
        direction TB
        ERR["⚠️ 에러 감지"]:::error
        GEMINI_E["✨ Gemini 2.5 Flash\n에러 분석"]:::gemini
        OLLAMA_F["🦙 Ollama\n수정 코드 재생성"]:::ollama
        LIMIT{"최대 3회\n초과?"}:::decision
        ERR --> GEMINI_E
        GEMINI_E --> OLLAMA_F
        OLLAMA_F --> LIMIT
    end

    subgraph OA["③ Output Agent"]
        direction TB
        GEMINI_O["✨ Gemini 2.5 Flash\n문서 정리 / 결과 출력"]:::gemini
    end

    subgraph EA["④ Email Agent  (요청 시에만)"]
        direction TB
        EMAIL_CHECK{"이메일\n발송 요청?"}:::decision
        EMAIL_SEND["📧 Gmail SMTP\n결과물 발송"]:::email
        EMAIL_CHECK -- "Yes" --> EMAIL_SEND
        EMAIL_CHECK -- "No" --> SKIP_EMAIL(["화면 출력만"]):::output
    end

    OUTPUT([" 📄 최종 결과물\n문서 / 코드 / 이메일 "]):::output

    INPUT --> RA
    RA --> CA
    RA --> OA
    DOCKER -- "✅ 성공" --> OA
    DOCKER -- "❌ 실패" --> ERR
    LIMIT -- "No → 재시도" --> OLLAMA_G
    LIMIT -- "Yes → 실패 리포트" --> OA
    CA -- "스킵" --> OA
    OA --> EA
    EMAIL_SEND --> OUTPUT
    SKIP_EMAIL --> OUTPUT


%%  ================================================================
%%  AI 협업 구조
%%  ================================================================
flowchart LR
    subgraph AI["🤝 AI 역할 분담"]
        direction TB
        G["✨ Gemini 2.5 Flash\n───────────────\n리서치 정리\n문서 작성\n에러 분석\n(무료 티어 일 20회)"]:::gemini
        P["🤖 GPT-5.4-mini\n───────────────\n코드 리뷰\n의도 검증\n(학교 API · 토큰 최소화)"]:::gpt
        O["🦙 Ollama  RTX 3080\n───────────────\nqwen2.5-coder\n코드 생성\n코드 수정\n(로컬 · 무료)"]:::ollama
    end

    G -- "에러 분석 결과 전달" --> O
    P -- "리뷰 통과 / 재작성 요청" --> O
    G -. "리서치 컨텍스트 공유" .-> P


%%  ================================================================
%%  Streamlit 대시보드 구조
%%  ================================================================
flowchart TD
    subgraph DASH["🖥️ Streamlit 대시보드 (localhost:8501)"]
        direction TB
        T1["🚀 실행 탭\n───────────────\n키워드/목적 입력\n파이프라인 단계별\n실시간 진행 표시"]:::app
        T2["📊 모니터링 탭\n───────────────\n각 에이전트\n단계별 입출력 확인"]:::app
        T3["📝 로그 탭\n───────────────\nLLM 호출 내역\n토큰 사용량 확인"]:::app
    end

    T1 -. "실행 후 데이터 공유" .-> T2
    T1 -. "실행 후 데이터 공유" .-> T3


%%  ================================================================
%%  Docker 샌드박스 격리 구조
%%  ================================================================
flowchart TD
    subgraph HOST["WSL2 호스트 (Ubuntu 24.04)"]
        APP["🐍 Python 앱\n(에이전트 파이프라인)"]:::app
        SOCK["/var/run/docker.sock"]:::tool
    end

    subgraph SB["🐳 Docker 샌드박스 (격리)"]
        direction TB
        RUN["코드 실행\nauto-vibe-sandbox"]:::docker
        FS["임시 파일시스템\n(호스트 마운트 없음)"]:::slate
        NET["네트워크 차단\n(network: none)"]:::slate
        TIME["타임아웃 60초\nCPU 2코어 / 메모리 1GB"]:::slate
        RUN --> FS
        RUN --> NET
        RUN --> TIME
    end

    APP -- "Docker API" --> SOCK
    SOCK -- "컨테이너 생성/실행" --> SB
    SB -- "실행 결과 / 에러 로그" --> APP


%%  ================================================================
%%  스타일 정의
%%  ================================================================
    classDef user      fill:#dbeafe,stroke:#93c5fd,color:#1e3a5f,font-weight:bold
    classDef gemini    fill:#fef9c3,stroke:#fde047,color:#713f12
    classDef gpt       fill:#dcfce7,stroke:#86efac,color:#14532d
    classDef ollama    fill:#fee2e2,stroke:#fca5a5,color:#7f1d1d
    classDef tool      fill:#ede9fe,stroke:#c4b5fd,color:#3b0764
    classDef docker    fill:#e0f2fe,stroke:#7dd3fc,color:#0c4a6e
    classDef error     fill:#fff1f2,stroke:#fda4af,color:#9f1239
    classDef decision  fill:#fef3c7,stroke:#fcd34d,color:#78350f
    classDef email     fill:#f0fdf4,stroke:#86efac,color:#14532d
    classDef output    fill:#d1fae5,stroke:#6ee7b7,color:#064e3b,font-weight:bold
    classDef slate     fill:#f1f5f9,stroke:#cbd5e1,color:#475569
    classDef app       fill:#f8fafc,stroke:#94a3b8,color:#1e293b
